{
  "enabledPlugins": {
    "agents-language-specialists@buildwithclaude": true,
    "rust-skills@rust-skills": true
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/require-commit-approval.sh"
          }
        ]
      }
    ]
  }
}
