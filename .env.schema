# Doradura — Environment Schema (varlock)
# https://varlock.dev
#
# @currentEnv=$DORADURA_ENV
# @defaultRequired=false
# @defaultSensitive=false
# ---

# ── Environment ───────────────────────────
# @type=enum(development, staging, production)
DORADURA_ENV=development

# Enable staging avatar & behaviour
# @type=boolean
DORADURA_STAGING=

# ── Bot (required) ────────────────────────
# Telegram bot token from @BotFather
# @sensitive @required
TELOXIDE_TOKEN=

# Alias for TELOXIDE_TOKEN
# @sensitive
BOT_TOKEN=

# ── Telegram API credentials ──────────────
# From https://my.telegram.org/apps — required for local Bot API
# @type=number
TELEGRAM_API_ID=

# @sensitive
TELEGRAM_API_HASH=

# ── Admin ─────────────────────────────────
# Bot admin username (without @), enables admin commands
# @type=string
ADMIN_USERNAME=

# Numeric Telegram user ID (get from @userinfobot)
# @type=number
ADMIN_USER_ID=

# Comma-separated admin IDs for multiple admins
# @type=string
ADMIN_IDS=

# ── Database ──────────────────────────────
# Database backend: sqlite (default, single-instance) or postgres (multi-instance)
# @type=enum(sqlite, postgres)
DATABASE_DRIVER=sqlite

# SQLite database file path
# @type=string
DATABASE_PATH=database.sqlite

# Database connection string (required in production).
# Accepts EITHER a postgres URL (postgres://…) when DATABASE_DRIVER=postgres
# OR a local SQLite path (e.g. /data/database.sqlite) when DATABASE_DRIVER=sqlite.
# Enforcing startsWith=postgres here would break the sqlite deployment;
# the code-level check in config.rs already rejects mismatches by driver.
# @sensitive @required=forEnv(production)
# @type=string
DATABASE_URL=

# Redis URL for distributed cooldowns and cache.
# Required only when DATABASE_DRIVER=postgres; optional when DATABASE_DRIVER=sqlite.
# Code-level check in config.rs already enforces the driver-dependent presence rule,
# so we don't mark this @required here (would break the sqlite deployment).
# @sensitive
# @type=string
REDIS_URL=

# ── Paths ─────────────────────────────────
# Download output directory (supports ~ expansion)
# @type=string
DOWNLOAD_FOLDER=

# Retention period (in days) for files in DOWNLOAD_FOLDER.
# Files older than this are deleted by the spawn_downloads_cleanup task
# every 6 hours. Default: 7
# @type=number
DOWNLOADS_RETENTION_DAYS=7

# Floor (in GB) for the high-res (2K/4K/8K) free-disk pre-check.
# Default 2 GB; small Railway volumes (4-5 GB total) need this low so
# legitimate 4K/8K downloads aren't blocked. The post-pre-flight
# `estimated_size × 3` check refines this once yt-dlp returns the
# real filesize estimate.
# @type=number
HIGHRES_MIN_DISK_GB=2

# Directory holding pre-baked test_*.mp4 files for the `/test_circle`
# admin command (small / medium / max-quality video-note inputs used
# to compare against Telegram's server-side transcoder).
# @type=string
TEST_CIRCLES_DIR=./test_circles

# Temporary files directory for processing
# @type=string
TEMP_FILES_DIR=/tmp

# Application log file path
# @type=string
LOG_FILE_PATH=app.log

# ── yt-dlp ────────────────────────────────
# Path or name of yt-dlp binary
# @type=string
YTDL_BIN=yt-dlp

# Path to YouTube cookies file (Netscape format)
# @type=string
YTDL_COOKIES_FILE=

# Browser to extract cookies from (chrome|firefox|safari|brave|edge)
# @type=string
YTDL_COOKIES_BROWSER=

# Instagram cookies file for authenticated access
# @type=string
INSTAGRAM_COOKIES_FILE=

# Instagram GraphQL doc_id — rotates every 2-4 weeks
# @type=string
INSTAGRAM_DOC_ID=10015901848480474

# ── Local Bot API (files >50 MB, up to 2 GB) ─
# @type=string(startsWith=http)
BOT_API_URL=

# Bot API data directory inside container
# @type=string
BOT_API_DATA_DIR=/data

# ── Webhook ───────────────────────────────
# Telegram webhook URL (leave empty for long polling)
# @type=string(startsWith=http)
WEBHOOK_URL=

# Secret token for webhook verification
# @sensitive
WEBHOOK_SECRET_TOKEN=

# Webhook endpoint path
# @type=string
WEBHOOK_PATH=/telegram/webhook

# Webhook listen address
# @type=string
WEBHOOK_LISTEN_ADDR=0.0.0.0:8080

# Telegram webhook max_connections (1-100)
# @type=number
WEBHOOK_MAX_CONNECTIONS=

# ── Proxy (required on Railway for YouTube) ─
# Primary WARP/SOCKS5 proxy for YouTube downloads
# @type=string
WARP_PROXY=

# File containing proxy list (one per line)
# @type=string
PROXY_FILE=

# Proxy rotation strategy
# @type=enum(round_robin, random, weighted, fixed)
PROXY_STRATEGY=round_robin

# Enable proxy rotation between downloads
# @type=boolean
PROXY_ROTATION_ENABLED=true

# Minimum proxy health score (0.0-1.0)
# @type=number
PROXY_MIN_HEALTH=0.5

# URL to fetch fresh proxy list
# @type=string(startsWith=http)
PROXY_UPDATE_URL=

# Seconds between proxy list refreshes
# @type=number
PROXY_UPDATE_INTERVAL=3600

# ── Queue ─────────────────────────────────
# Max parallel downloads (keep low for YouTube rate limits)
# @type=number
QUEUE_MAX_CONCURRENT=2

# Milliseconds between starting new download tasks
# @type=number
QUEUE_INTER_DOWNLOAD_DELAY_MS=3000

# Milliseconds between queue polling cycles
# @type=number
QUEUE_CHECK_INTERVAL_MS=100

# ── Subscription pricing (Telegram Stars) ─
# Premium plan price (~$6/month)
# @type=number
PREMIUM_PRICE_STARS=350

# VIP plan price (~$15/month)
# @type=number
VIP_PRICE_STARS=850

# ── Metrics & Monitoring ──────────────────
# Enable Prometheus metrics collection
# @type=boolean
METRICS_ENABLED=true

# Metrics HTTP server port
# @type=number
METRICS_PORT=9090

# Prometheus server URL (for reference)
# @type=string(startsWith=http)
PROMETHEUS_URL=http://prometheus:9090

# ── Alerts ────────────────────────────────
# Enable alerting system
# @type=boolean
ALERTS_ENABLED=true

# Error rate % threshold for alerts
# @type=number
ALERT_ERROR_RATE_THRESHOLD=5.0

# Queue depth threshold for alerts
# @type=number
ALERT_QUEUE_DEPTH_THRESHOLD=50

# Retry rate % threshold for alerts
# @type=number
ALERT_RETRY_RATE_THRESHOLD=30.0

# ── Analytics ─────────────────────────────
# Seconds between analytics cache refreshes
# @type=number
ANALYTICS_CACHE_UPDATE_INTERVAL=300

# ── Health checks ─────────────────────────
# Enable smoke test scheduler
# @type=boolean
HEALTH_CHECK_ENABLED=true

# Seconds between health check runs
# @type=number
HEALTH_CHECK_INTERVAL_SECS=60

# ── Health monitor service ────────────────
# URL to poll for health status
# @type=string(startsWith=http)
HEALTH_MONITOR_HEALTH_URL=http://localhost:9090/health

# Seconds between health monitor checks
# @type=number
HEALTH_MONITOR_INTERVAL_SECS=30

# Consecutive failures before recovery action
# @type=number
HEALTH_MONITOR_FAIL_THRESHOLD=3

# Seconds to wait after container start before first check
# @type=number
HEALTH_MONITOR_STARTUP_DELAY_SECS=60

# ── Downsub gRPC (summaries & subtitles) ──
# @type=string(startsWith=http)
DOWNSUB_GRPC_ENDPOINT=

# ── Copyright tag in sent files ───────────
# Bot username tag appended to filenames
# @type=string
BOT_TAG=@DoraDuraDoraDuraBot

# Enable copyright tagging
# @type=boolean
COPYRIGHT_ENABLED=true

# ── Web / Share pages ─────────────────────
# Base URL for public share pages
# @type=string(startsWith=http)
WEB_BASE_URL=

# Web server port (falls back to PORT, then 3000)
# @type=number
WEB_PORT=

# Railway-injected port
# @type=number
PORT=

# ── Content Watcher / Subscriptions ───────
# Seconds between watcher scheduler runs
# @type=number
WATCHER_CHECK_INTERVAL_SECS=900

# Max API requests per watcher cycle
# @type=number
WATCHER_MAX_REQUESTS_PER_CYCLE=60

# Consecutive errors before auto-disabling a subscription
# @type=number
WATCHER_MAX_CONSECUTIVE_ERRORS=10

# Max subscriptions per plan tier
# @type=number
WATCHER_MAX_SUBS_FREE=3

# @type=number
WATCHER_MAX_SUBS_PREMIUM=15

# @type=number
WATCHER_MAX_SUBS_VIP=50

# ── Spotify API ───────────────────────────
# @sensitive
SPOTIFY_CLIENT_ID=

# @sensitive
SPOTIFY_CLIENT_SECRET=

# ── Yandex Music ──────────────────────────
# Yandex Music cookies file
# @type=string
YM_COOKIES_FILE=

# Proxy for Yandex Music (geo-restricted)
# @type=string
YM_PROXY=

# ── Genius Lyrics API ─────────────────────
# Client access token for structured lyrics (optional)
# @docs(https://genius.com/api-clients)
# @sensitive
GENIUS_CLIENT_TOKEN=

# ── MTProto (experimental) ────────────────
# Session file path for grammers MTProto client
# @type=string
MTPROTO_SESSION_PATH=mtproto_session.bin

# ── Third-party API keys ──────────────────
# Anthropic API key for AI-assisted features (optional)
# @sensitive
ANTHROPIC_API_KEY=

# Vlipsy API key for voice-sticker integration (optional)
# @sensitive
VLIPSY_API_KEY=

# Generic cookies file fallback (used when YTDL_COOKIES_FILE unset)
# Default: /data/cookies.txt inside container
# @type=string
COOKIES_FILE=

# Another alias for TELOXIDE_TOKEN (code falls back through
# TELOXIDE_TOKEN → BOT_TOKEN → TELEGRAM_BOT_TOKEN)
# @sensitive
TELEGRAM_BOT_TOKEN=

# ── Admin endpoints ───────────────────────
# Comma-separated list of IPs/CIDRs allowed to hit admin HTTP endpoints
# @type=string
ADMIN_IP_ALLOWLIST=

# Number of trusted proxy hops (for X-Forwarded-For parsing)
# @type=number
TRUSTED_PROXY_HOPS=

# Bearer token required for /metrics endpoint (when set, redacts unauthenticated requests)
# @sensitive
METRICS_AUTH_TOKEN=

# ── Bot API diagnostics ───────────────────
# Path to local Bot API server's log file (inside container)
# @type=string
BOT_API_LOG_PATH=

# Max bytes to return when admin tails the Bot API log
# @type=number
BOT_API_LOG_TAIL_BYTES=

# ── Stats reporter ────────────────────────
# Hours between scheduled stats broadcasts to admin
# @type=number
STATS_REPORT_INTERVAL=

# ── Telegram test recording ───────────────
# Record/replay mode for integration tests (record | replay | off)
# @type=enum(record, replay, off)
TELEGRAM_RECORD_MODE=

# ── Runtime-injected (NOT user-configurable) ─
# These are set automatically by Railway / build system.
# Listed here so schema stays a complete catalog of every env var
# the code reads — used by CI drift check.

# Git branch name (build-time injection for /version endpoint)
# @type=string
GIT_BRANCH=

# Git commit SHA (build-time injection for /version endpoint)
# @type=string
GIT_COMMIT=

# Railway-injected git branch (fallback for GIT_BRANCH)
# @type=string
RAILWAY_GIT_BRANCH=

# Railway-injected git commit SHA (fallback for GIT_COMMIT)
# @type=string
RAILWAY_GIT_COMMIT_SHA=

# Container start timestamp in epoch ms (set by entrypoint, used for uptime metric)
# @type=number
CONTAINER_START_MS=
